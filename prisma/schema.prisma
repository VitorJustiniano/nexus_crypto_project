// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  userId    String    @id @default(uuid())
  createdAt DateTime  @default(now())
  email     String    @unique
  password  String    
  name      String?
  role      Role     @default(USER)
  wallet    Wallet?
  ledger    Ledger[]    
}

model Wallet {
  walletId        Int         @id @default(autoincrement())
  user            User        @relation(fields: [userId], references: [userId])
  userId          String      @unique
  createdAt       DateTime    @default(now())
  walletBalance   WalletBalance[]
}

model WalletBalance {
  walletBalanceId   Int       @id @default(autoincrement())
  wallet            Wallet    @relation(fields: [walletId], references: [walletId])
  walletId          Int
  token             Token     @default(BRL)
  amount            Decimal   @default(0)
                              @@unique([walletId, token])
}

model idempotencyKey {
  Key               String     @id
  datacreated       DateTime   @default(now())
}

model Ledger {
  ledgerId          String      @id @default(uuid())
  user              User        @relation(fields: [userId], references: [userId])
  userId            String      
  DateTime          DateTime    @default(now())
  token             Token
  balance_before    Decimal
  balance_after     Decimal
  moved_value       Decimal
  transaction_type  TransactionType
}

enum Role {
  USER
  ADMIN
}

enum Token {
  BRL
  BTC
  ETH
}

enum TransactionType {
  DEPOSIT
  SWAP_IN
  SWAP_OUT
  SWAP_FEE
  WITHDRAWAL
}
